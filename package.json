{
  "name": "herm-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces --if-present",
    "test:ci": "npm run test:ci --workspaces --if-present",
    "build": "npm run build --workspaces",
    "verify": "npm run lint && npm run typecheck && npm run test:ci && npm run build",
    "verify:strict": "npm run lint && npm run format:check && npm run typecheck && npm run test:ci && npm run build",
    "db:push": "npx prisma db push --schema=prisma/schema.prisma",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:demo": "npx tsx prisma/seeds/demo-user.ts",
    "db:studio": "npx prisma studio --schema=prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "db:seed:jurisdictions": "npx tsx prisma/seeds/jurisdictions.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@prisma/client": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "prettier": "^3.3.3",
    "prisma": "^5.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.4.0"
  },
  "dependencies": {
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^17.0.2",
    "stripe": "^21.0.1"
  }
}
