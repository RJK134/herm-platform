{
  "name": "herm-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "db:push": "npx prisma db push --schema=prisma/schema.prisma",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:demo": "npx tsx prisma/seeds/demo-user.ts",
    "db:studio": "npx prisma studio --schema=prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "db:seed:jurisdictions": "npx tsx prisma/seeds/jurisdictions.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@prisma/client": "^5.10.0",
    "concurrently": "^8.2.2",
    "prisma": "^5.10.0",
    "tsx": "^4.7.0"
  },
  "dependencies": {
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^17.0.2",
    "stripe": "^21.0.1"
  }
}
