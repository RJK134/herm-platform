{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx prisma generate --schema=prisma/schema.prisma && npm run build --workspace=@herm-platform/server && npm run build --workspace=@herm-platform/client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install --include=dev",
  "framework": null,
  "rewrites": [
    {
      "source": "/metrics",
      "destination": "/api/metrics"
    },
    {
      "source": "/scim/v2/:path*",
      "destination": "/api/scim/v2/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "github": {
    "silent": true
  }
}
