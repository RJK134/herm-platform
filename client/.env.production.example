# Vercel build env-vars for the herm-platform SPA.
# Set these in the Vercel project's Settings → Environment Variables
# panel (Production scope). They are baked into the JS bundle at
# build time — Vite reads VITE_* variables and inlines them.

# Absolute origin of the API service (Railway, Fly, etc.). NO trailing
# slash and NO `/api` suffix — the API client appends `/api` itself.
# Example: https://herm-platform-api.up.railway.app
VITE_API_URL=https://your-railway-api-host
