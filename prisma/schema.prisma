generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institution {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  country      String
  tier         String               @default("free")
  logoUrl      String?
  domain       String?
  users        User[]
  baskets      CapabilityBasket[]
  projects     ProcurementProject[]
  subscription        Subscription?
  evaluationProjects  EvaluationProject[]
  apiKeys      ApiKey[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Subscription {
  id                   String           @id @default(cuid())
  institutionId        String           @unique
  institution          Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  tier                 SubscriptionTier @default(FREE)
  status               String           @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  payments             Payment[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

enum SubscriptionTier {
  FREE
  PROFESSIONAL
  ENTERPRISE
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String
  passwordHash  String      @default("")
  role          UserRole    @default(VIEWER)
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  evaluationMemberships      EvaluationMember[]
  domainAssignments          EvaluationDomainAssignment[] @relation("DomainAssignments")
  notifications Notification[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@index([institutionId])
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTION_ADMIN
  PROCUREMENT_LEAD
  EVALUATOR
  VENDOR_ADMIN
  VENDOR_CONTRIBUTOR
  VIEWER
}

model HermFamily {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  category     String
  sortOrder    Int
  capabilities      HermCapability[]
  domainAssignments EvaluationDomainAssignment[]
}

model HermCapability {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  description   String?
  familyId      String
  family        HermFamily    @relation(fields: [familyId], references: [id])
  sortOrder     Int
  scores        Score[]
  basketItems   BasketItem[]
  versionScores VersionScore[]
  @@index([familyId])
}

model VendorSystem {
  id                   String                  @id @default(cuid())
  name                 String
  vendor               String
  category             String
  description          String?
  regions              String[]
  cloudNative          Boolean                 @default(false)
  website              String?
  logoUrl              String?
  isOwnSystem          Boolean                 @default(false)
  scores                  Score[]
  profile                 VendorProfile?
  versions                VendorVersion[]
  tcoEstimates            TcoEstimate[]
  shortlistEntries        ShortlistEntry[]
  integrationTargets      IntegrationAssessment[]
  architectureAssessments ArchitectureAssessment[]
  valueAnalyses           ValueAnalysis[]
  evaluations             ProcurementEvaluation[]
  vendorAccount           VendorAccount?
  evaluationEntries       EvaluationSystem[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
}

model Score {
  id           String         @id @default(cuid())
  systemId     String
  system       VendorSystem   @relation(fields: [systemId], references: [id])
  capabilityId String
  capability   HermCapability @relation(fields: [capabilityId], references: [id])
  value        Int
  evidence     String?
  source       String?
  version      Int            @default(1)
  scoredBy     String?
  scoredAt     DateTime       @default(now())
  @@unique([systemId, capabilityId, version])
  @@index([systemId])
  @@index([capabilityId])
}

model CapabilityBasket {
  id            String      @id @default(cuid())
  name          String
  description   String?
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  createdById   String
  items         BasketItem[]
  isTemplate    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model BasketItem {
  id           String           @id @default(cuid())
  basketId     String
  basket       CapabilityBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  capabilityId String
  capability   HermCapability   @relation(fields: [capabilityId], references: [id])
  priority     String           @default("must")
  weight       Int              @default(1)
  notes        String?
  @@unique([basketId, capabilityId])
}

model ProcurementProject {
  id               String      @id @default(cuid())
  name             String
  description      String?
  institutionId    String
  institution      Institution @relation(fields: [institutionId], references: [id])
  status           String      @default("draft")
  basketId         String?
  jurisdiction     String      @default("UK")
  estimatedValue   Decimal?    @db.Decimal(14, 2)
  procurementRoute String?     @default("open")
  startDate        DateTime?
  targetAwardDate  DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  workflow         ProcurementWorkflow?
  shortlist        ShortlistEntry[]
  stages           ProcurementStage[]
  evaluations      ProcurementEvaluation[]
  complianceChecks ComplianceCheck[]
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  @@index([entityType, entityId])
  @@index([userId])
}

model VendorVersion {
  id           String         @id @default(cuid())
  systemId     String
  system       VendorSystem   @relation(fields: [systemId], references: [id])
  versionName  String
  releaseDate  DateTime?
  endOfLife    DateTime?
  changelog    String?
  scores       VersionScore[]
  createdAt    DateTime       @default(now())
  @@index([systemId])
}

model VersionScore {
  id             String         @id @default(cuid())
  versionId      String
  version        VendorVersion  @relation(fields: [versionId], references: [id])
  capabilityId   String
  capability     HermCapability @relation(fields: [capabilityId], references: [id])
  value          Int
  changeFromPrev Int?
  evidence       String?
  @@unique([versionId, capabilityId])
  @@index([versionId])
}

model VendorProfile {
  id                   String       @id @default(cuid())
  systemId             String       @unique
  system               VendorSystem @relation(fields: [systemId], references: [id])
  foundedYear          Int?
  headquarters         String?
  employees            String?
  marketShare          String?
  gartnerPosition      String?
  deploymentModel      String[]
  techStack            String?
  apiStandards         String[]
  integrationProtocols String[]
  certifications       String[]
  pricingModel         String?
  typicalCostRange     String?
  implementationTime   String?
  keyStrengths         String[]
  knownLimitations     String[]
  recentNews           String?
  lastUpdated          DateTime     @default(now())
}

model ResearchItem {
  id              String   @id @default(cuid())
  title           String
  publisher       String
  year            Int
  category        String
  tags            String[]
  summary         String?
  url             String?
  relevantSystems String[]
  createdAt       DateTime @default(now())
}

model ScoringMethodology {
  id        String   @id @default(cuid())
  category  String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  context   Json?
  createdAt DateTime @default(now())
  @@index([sessionId])
}

model TcoEstimate {
  id                 String        @id @default(cuid())
  name               String
  institutionSize    String
  studentFte         Int
  staffFte           Int
  currency           String        @default("GBP")
  horizonYears       Int           @default(5)
  systemId           String?
  system             VendorSystem? @relation(fields: [systemId], references: [id])
  licenceCostYear1   Float         @default(0)
  licenceCostGrowth  Float         @default(0.03)
  implementationCost Float         @default(0)
  internalStaffCost  Float         @default(0)
  trainingCost       Float         @default(0)
  infrastructureCost Float         @default(0)
  integrationCost    Float         @default(0)
  supportCost        Float         @default(0)
  customDevCost      Float         @default(0)
  totalTco           Float         @default(0)
  annualRunRate      Float         @default(0)
  perStudentCost     Float         @default(0)
  notes              String?
  institutionId      String?
  createdById        String        @default("anonymous")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  @@index([systemId])
}

model ProcurementWorkflow {
  id           String             @id @default(cuid())
  projectId    String             @unique
  project      ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentStage Int                @default(1)
  stages       WorkflowStage[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model WorkflowStage {
  id          String              @id @default(cuid())
  workflowId  String
  workflow    ProcurementWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stageNumber Int
  title       String
  status      String              @default("pending")
  completedAt DateTime?
  notes       String?
  outputs     Json?
  @@unique([workflowId, stageNumber])
  @@index([workflowId])
}

model ShortlistEntry {
  id        String             @id @default(cuid())
  projectId String
  project   ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  systemId  String
  system    VendorSystem       @relation(fields: [systemId], references: [id])
  status    String             @default("longlist")
  score     Float?
  notes     String?
  addedAt   DateTime           @default(now())
  @@unique([projectId, systemId])
  @@index([projectId])
}

model IntegrationAssessment {
  id              String        @id @default(cuid())
  name            String
  currentSystems  Json
  targetSystemId  String?
  targetSystem    VendorSystem? @relation(fields: [targetSystemId], references: [id])
  complexityScore Int           @default(0)
  riskLevel       String        @default("medium")
  findings        Json?
  createdById     String        @default("anonymous")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ── Architecture & System Landscape Assessment ────────────────────────────────

model ArchitectureAssessment {
  id                  String        @id @default(cuid())
  name                String
  institutionId       String?
  currentSystems      Json          // SystemNode[] — each with name, category, age, criticality, vendor
  integrationLinks    Json          // IntegrationLink[] — { fromId, toId, protocol, complexity }
  architecturePattern String        @default("point-to-point")
  targetSystemId      String?
  targetSystem        VendorSystem? @relation(fields: [targetSystemId], references: [id])
  // Risk dimensions (0–100 each)
  dataRisk            Int           @default(0)
  cutoverRisk         Int           @default(0)
  integrationRisk     Int           @default(0)
  changeRisk          Int           @default(0)
  // Computed scores
  overallRisk         Int           @default(0)
  readinessScore      Int           @default(0)
  recommendations     Json?         // RecommendationItem[]
  notes               String?
  createdById         String        @default("anonymous")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

// ── Cost & Value Analysis (Business Case Builder) ─────────────────────────────

model ValueAnalysis {
  id                      String        @id @default(cuid())
  name                    String
  institutionId           String?
  systemId                String?
  targetSystem            VendorSystem? @relation(fields: [systemId], references: [id])
  // Institution profile
  studentFte              Int           @default(10000)
  staffFte                Int           @default(500)
  institutionType         String        @default("pre-92")
  // Current state costs (annual, GBP)
  currentSystemCostAnnual Float         @default(0)
  currentMaintenanceCost  Float         @default(0)
  currentSupportCost      Float         @default(0)
  // Operational benefits inputs
  adminEfficiencyPct      Float         @default(0)
  adminStaffAffected      Int           @default(0)
  avgAdminSalaryGbp       Float         @default(35000)
  registryEfficiencyPct   Float         @default(0)
  registryStaffAffected   Int           @default(0)
  avgRegistrySalaryGbp    Float         @default(42000)
  // Strategic benefits inputs
  errorReductionPct       Float         @default(0)
  errorCostCurrentAnnual  Float         @default(0)
  complianceSavingAnnual  Float         @default(0)
  studentExperienceValue  Float         @default(0)
  otherBenefitsAnnual     Float         @default(0)
  // Investment costs
  implementationCost      Float         @default(0)
  annualLicenceCost       Float         @default(0)
  annualSupportCost       Float         @default(0)
  annualInternalStaffCost Float         @default(0)
  // Calculated results
  totalAnnualBenefits     Float         @default(0)
  totalAnnualCosts        Float         @default(0)
  netAnnualBenefit        Float         @default(0)
  roi3Year                Float         @default(0)
  roi5Year                Float         @default(0)
  npv5Year                Float         @default(0)
  paybackMonths           Int           @default(0)
  notes                   String?
  createdById             String        @default("anonymous")
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  @@index([systemId])
}

// ── Document Generation ───────────────────────────────────────────────────────

model GeneratedDocument {
  id              String         @id @default(cuid())
  title           String
  type            DocumentType
  institutionId   String?
  projectId       String?
  basketId        String?
  tcoEstimateId   String?
  valueAnalysisId String?
  sections        Json           // DocumentSection[] — { id, title, content, order, locked }
  metadata        Json?          // { author, institution, date, version, classification }
  status          DocumentStatus @default(DRAFT)
  wordCount       Int            @default(0)
  createdById     String         @default("anonymous")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum DocumentType {
  BUSINESS_CASE
  RFP_ITT
  SHORTLIST_REPORT
  REQUIREMENTS_SPEC
  EXECUTIVE_SUMMARY
}

enum DocumentStatus {
  DRAFT
  REVIEW
  FINAL
  ARCHIVED
}

// ── Phase 4: Multi-Jurisdiction Procurement Engine ───────────────────────────

model ProcurementJurisdiction {
  id                  String   @id @default(cuid())
  code                String   @unique
  name                String
  legislation         String
  thresholds          Json
  minimumTimelines    Json
  mandatoryStages     Json
  noticeRequirements  Json
  standstillPeriod    Int?
  rules               Json
  isActive            Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model ProcurementStage {
  id               String             @id @default(cuid())
  projectId        String
  project          ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageCode        String
  stageName        String
  stageOrder       Int
  status           StageStatus        @default(NOT_STARTED)
  startDate        DateTime?
  dueDate          DateTime?
  completedDate    DateTime?
  assignedTo       String?
  complianceChecks Json?
  notes            String?
  documents        StageDocument[]
  approvals        StageApproval[]
  tasks            StageTask[]
  @@index([projectId])
  @@unique([projectId, stageCode])
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  AWAITING_APPROVAL
  APPROVED
  COMPLETED
  SKIPPED
  BLOCKED
}

model StageTask {
  id          String           @id @default(cuid())
  stageId     String
  stage       ProcurementStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  title       String
  description String?
  assignedTo  String?
  dueDate     DateTime?
  isCompleted Boolean          @default(false)
  isMandatory Boolean          @default(false)
  completedAt DateTime?
  completedBy String?
  sortOrder   Int
  @@index([stageId])
}

model StageApproval {
  id           String           @id @default(cuid())
  stageId      String
  stage        ProcurementStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  approverRole String
  approverName String?
  status       String           @default("pending")
  requestedAt  DateTime         @default(now())
  decidedAt    DateTime?
  comments     String?
  @@index([stageId])
}

model StageDocument {
  id                    String           @id @default(cuid())
  stageId               String
  stage                 ProcurementStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  documentType          String
  title                 String
  content               Json?
  status                String           @default("draft")
  version               Int              @default(1)
  generatedFromTemplate Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  @@index([stageId])
}

model ProcurementEvaluation {
  id                  String             @id @default(cuid())
  projectId           String
  project             ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  systemId            String
  system              VendorSystem       @relation(fields: [systemId], references: [id])
  evaluatorId         String?
  evaluatorName       String?
  hermScore           Decimal?           @db.Decimal(5, 2)
  technicalScore      Decimal?           @db.Decimal(5, 2)
  commercialScore     Decimal?           @db.Decimal(5, 2)
  implementationScore Decimal?           @db.Decimal(5, 2)
  referenceScore      Decimal?           @db.Decimal(5, 2)
  overallScore        Decimal?           @db.Decimal(5, 2)
  weightingProfile    Json?
  recommendation      String?
  notes               String?
  submittedAt         DateTime?
  @@unique([projectId, systemId, evaluatorId])
  @@index([projectId])
}

model ComplianceCheck {
  id             String             @id @default(cuid())
  projectId      String
  project        ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checkCode      String
  checkName      String
  jurisdictionId String
  isRequired     Boolean
  isPassed       Boolean?
  evidence       String?
  checkedAt      DateTime?
  checkedBy      String?
  @@index([projectId])
}

// ── Phase 5: Vendor Portal, Team Workspaces, Payments ────────────────────────

model VendorAccount {
  id                   String             @id @default(cuid())
  companyName          String
  contactEmail         String             @unique
  contactName          String
  systemId             String?            @unique
  system               VendorSystem?      @relation(fields: [systemId], references: [id])
  tier                 VendorTier         @default(BASIC)
  status               String             @default("pending")
  websiteUrl           String?
  phone                String?
  address              String?
  logoUrl              String?
  description          String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  approvedAt           DateTime?
  approvedBy           String?
  users                VendorUser[]
  submissions          VendorSubmission[]
  analytics            VendorAnalytic[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum VendorTier {
  BASIC
  ENHANCED
  PREMIUM
}

model VendorUser {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  role            String        @default("contributor")
  vendorAccountId String
  vendorAccount   VendorAccount @relation(fields: [vendorAccountId], references: [id])
  passwordHash    String
  lastLogin       DateTime?
  createdAt       DateTime      @default(now())
  @@index([vendorAccountId])
}

model VendorSubmission {
  id              String        @id @default(cuid())
  vendorAccountId String
  vendorAccount   VendorAccount @relation(fields: [vendorAccountId], references: [id])
  type            String
  data            Json
  status          String        @default("pending")
  reviewedBy      String?
  reviewNotes     String?
  submittedAt     DateTime      @default(now())
  reviewedAt      DateTime?
  @@index([vendorAccountId])
}

model VendorAnalytic {
  id              String        @id @default(cuid())
  vendorAccountId String
  vendorAccount   VendorAccount @relation(fields: [vendorAccountId], references: [id])
  metric          String
  value           Int
  period          String
  createdAt       DateTime      @default(now())
  @@index([vendorAccountId, metric, period])
}

model EvaluationProject {
  id                String                       @id @default(cuid())
  name              String
  description       String?
  institutionId     String
  institution       Institution                  @relation(fields: [institutionId], references: [id])
  leadUserId        String
  status            String                       @default("planning")
  basketId          String?
  deadline          DateTime?
  systems           EvaluationSystem[]
  members           EvaluationMember[]
  domainAssignments EvaluationDomainAssignment[]
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  @@index([institutionId])
}

model EvaluationSystem {
  id        String            @id @default(cuid())
  projectId String
  project   EvaluationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  systemId  String
  system    VendorSystem      @relation(fields: [systemId], references: [id])
  @@unique([projectId, systemId])
}

model EvaluationMember {
  id              String            @id @default(cuid())
  projectId       String
  project         EvaluationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  role            String            @default("evaluator")
  assignedDomains String[]
  @@unique([projectId, userId])
}

model EvaluationDomainAssignment {
  id           String            @id @default(cuid())
  projectId    String
  project      EvaluationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  familyId     String
  family       HermFamily        @relation(fields: [familyId], references: [id])
  assignedToId String
  assignedTo   User              @relation("DomainAssignments", fields: [assignedToId], references: [id])
  status       String            @default("pending")
  score        Json?
  completedAt  DateTime?
  scores       EvaluationDomainScore[]
  @@unique([projectId, familyId])
}

model EvaluationDomainScore {
  id           String                     @id @default(cuid())
  assignmentId String
  assignment   EvaluationDomainAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  systemId     String
  capabilityId String
  value        Int
  notes        String?
  scoredAt     DateTime                   @default(now())
  @@unique([assignmentId, systemId, capabilityId])
}

model Payment {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("GBP")
  status          String
  stripePaymentId String?      @unique
  invoiceUrl      String?
  paidAt          DateTime?
  createdAt       DateTime     @default(now())
}

// ── Phase 6: Notifications & API Keys ────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([userId, isRead])
}

model ApiKey {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  keyHash       String      @unique
  keyPrefix     String
  permissions   String[]
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  @@index([institutionId])
}
