generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Multi-Framework Capability Management ────────────────────────────────────
// Framework is the root model. HERM is one framework instance (CC BY-NC-SA 4.0).
// The platform functions fully without HERM loaded — paid tiers use the
// proprietary FHE Capability Framework by default.

model Framework {
  id              String  @id @default(cuid())
  slug            String  @unique // "herm-v3.1", "fhe-capability-framework"
  name            String // "UCISA HERM v3.1"
  version         String // "3.1"
  publisher       String // "CAUDIT", "FHE"
  description     String?
  licenceType     String // "CC-BY-NC-SA-4.0", "PROPRIETARY"
  licenceNotice   String? // Full attribution text
  licenceUrl      String? // "https://creativecommons.org/licenses/by-nc-sa/4.0/"
  isPublic        Boolean @default(false) // true = available on free tier
  isDefault       Boolean @default(false) // true = default for paid tier
  isActive        Boolean @default(true)
  domainCount     Int     @default(0)
  capabilityCount Int     @default(0)
  metadata        Json?

  domains          FrameworkDomain[]
  capabilities     Capability[]
  scores           CapabilityScore[]
  versionScores    VersionScore[]
  baskets          CapabilityBasket[]
  evaluations      EvaluationProject[]
  mappingsAsSource FrameworkMapping[]  @relation("MappingSource")
  mappingsAsTarget FrameworkMapping[]  @relation("MappingTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublic])
  @@index([isDefault])
}

model FrameworkDomain {
  id              String    @id @default(cuid())
  frameworkId     String
  framework       Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  code            String // "LT", "RE" for HERM; "DL", "SL" for FHE
  name            String // "Learning & Teaching"
  category        String
  description     String?
  sortOrder       Int
  colour          String? // Hex colour for UI
  capabilityCount Int       @default(0)

  capabilities      Capability[]
  domainAssignments EvaluationDomainAssignment[]

  @@unique([frameworkId, code])
  @@index([frameworkId])
}

model Capability {
  id          String          @id @default(cuid())
  frameworkId String
  framework   Framework       @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  code        String // "BC001" for HERM; "FHE-DL-001" for FHE
  name        String
  description String?
  domainId    String
  domain      FrameworkDomain @relation(fields: [domainId], references: [id], onDelete: Restrict)
  sortOrder   Int
  level       Int             @default(1) // Hierarchy depth
  parentId    String? // Self-ref for sub-capabilities
  parent      Capability?     @relation("CapabilityHierarchy", fields: [parentId], references: [id])
  children    Capability[]    @relation("CapabilityHierarchy")

  scores         CapabilityScore[]
  basketItems    BasketItem[]
  versionScores  VersionScore[]
  sourceMappings CapabilityMapping[] @relation("SourceCapabilityMapping")
  targetMappings CapabilityMapping[] @relation("TargetCapabilityMapping")

  @@unique([frameworkId, code])
  @@index([frameworkId])
  @@index([domainId])
  @@index([parentId])
}

// ── Platform Core ────────────────────────────────────────────────────────────

model Institution {
  id                 String                @id @default(cuid())
  name               String
  slug               String                @unique
  country            String
  tier               String                @default("free")
  logoUrl            String?
  domain             String?
  users              User[]
  baskets            CapabilityBasket[]
  projects           ProcurementProject[]
  subscription       Subscription?
  evaluationProjects EvaluationProject[]
  apiKeys            ApiKey[]
  ssoProviders       SsoIdentityProvider[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

// Phase 10.7 (scaffold) + Phase 11.13 (multi-IdP per tenant): per-
// institution SSO identity-provider config. Originally 1:1 (one IdP
// per institution); Phase 11.13 dropped the unique constraint on
// `institutionId` and added `priority` so a tenant can register
// multiple IdPs (main university + a department's IdP, or a SAML
// federation IdP alongside a vendor-managed OIDC backstop). Discovery
// returns every enabled row sorted by priority; the login flow accepts
// an `idpId` query parameter to disambiguate.
//
// See docs/adr/0001-sso-architecture.md (Q8) for the original
// out-of-scope-for-v1 framing and the migration rationale.
model SsoIdentityProvider {
  id               String      @id @default(cuid())
  institutionId    String
  institution      Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  // SAML or OIDC. The flow paths in /api/sso branch on this column.
  protocol         SsoProtocol
  // Display label shown on the discovery page ("Sign in with <displayName>").
  displayName      String
  // SAML-specific. Null for OIDC providers.
  samlEntityId     String?
  samlSsoUrl       String?
  // PEM-encoded x509 cert used to verify SAML assertions. Stored as TEXT
  // (multi-line). Rotation is operator-driven for now — see ADR.
  samlCert         String?
  // OIDC-specific. Null for SAML providers.
  oidcIssuer       String?
  oidcClientId     String?
  // Stored as-is in this column; protection at rest relies on the
  // deployment's database encryption (Postgres TDE, RDS at-rest, etc.)
  // as described in docs/adr/0001-sso-architecture.md. Application-layer
  // envelope encryption is a future enhancement; until then operators
  // MUST treat this column as sensitive and ensure at-rest encryption
  // is enabled on the production database.
  oidcClientSecret String?
  // JIT-provisioning policy: when `true`, an unknown user from the IdP
  // is created on first login. When `false`, the login fails and an
  // INSTITUTION_ADMIN must pre-provision the user. Default: true.
  jitProvisioning  Boolean     @default(true)
  // Default role assigned to JIT-provisioned users.
  defaultRole      UserRole    @default(VIEWER)
  enabled          Boolean     @default(false)
  // Phase 11.13 — sort order for discovery + the "primary IdP" the
  // bare `/api/sso/:slug/login` endpoint redirects to when no `idpId`
  // is given. Lower = higher priority. Default 100 leaves room for
  // operators to insert higher-priority overrides without renumbering.
  priority         Int         @default(100)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([institutionId, enabled, priority])
}

enum SsoProtocol {
  SAML
  OIDC
}

model Subscription {
  id                   String           @id @default(cuid())
  institutionId        String           @unique
  institution          Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  tier                 SubscriptionTier @default(FREE)
  status               String           @default("active")
  // Dunning state — independent of `status`. `status` says "is this a
  // paying subscription?" (active / cancelled). `dunningState` says "are
  // we successfully collecting payments?" (active / past_due / paused /
  // cancelled). Stripe's invoice.payment_failed and charge.dispute.created
  // events flip this to past_due / paused; a successful subsequent charge
  // resets it to active.
  dunningState         DunningState     @default(active)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  payments             Payment[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

enum SubscriptionTier {
  FREE
  PROFESSIONAL
  ENTERPRISE
}

enum DunningState {
  active
  past_due
  paused
  cancelled
}

model User {
  id                    String                       @id @default(cuid())
  email                 String                       @unique
  name                  String
  passwordHash          String                       @default("")
  role                  UserRole                     @default(VIEWER)
  institutionId         String
  institution           Institution                  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  // Phase 10.8 — TOTP MFA. `mfaSecret` is the base32-encoded shared secret;
  // it is set by `enroll` and only becomes "active" once `verify` confirms
  // a working TOTP code (at which point `mfaEnabledAt` is stamped). When
  // `mfaEnabledAt` is null the secret is staged but not yet enforced —
  // the user can re-enroll without a verify step. At-rest encryption of
  // the secret is the deployment's responsibility (Postgres TDE).
  mfaSecret             String?
  mfaEnabledAt          DateTime?
  // Phase 10.10 — Q3 SSO account collision policy. When a user signed up
  // via password and their institution later enables SSO, the first SSO
  // login links the IdP identity to this row by email and flips this
  // flag to true so subsequent password logins are rejected. The
  // password hash stays in the row so support can audit; we just refuse
  // to validate against it. Null/false on every other account.
  passwordLoginDisabled Boolean                      @default(false)
  // Phase 11.9 — Soft delete. Set by the GDPR right-to-erasure path
  // (Article 17) and any future admin-initiated removals. The row is
  // kept for the retention window (RETENTION_GRACE_DAYS) so an
  // accidental erasure can be reversed; the retention scheduler then
  // hard-deletes anything past the window. The auth chokepoint
  // (`authenticateJWT` + login) treats `deletedAt != null` as "this
  // user does not exist" so soft-deleted accounts cannot transact even
  // while the row physically remains. PII fields (email, name, mfa
  // secret) are scrubbed at the moment of soft-delete so the
  // grace-period row already minimises personal data.
  deletedAt             DateTime?
  // Phase 11.11 — SCIM 2.0 provisioning. Identifier the IdP / SCIM
  // client uses to track this user on its side. Optional and unique
  // per-institution (composite uniqueness, not global) so two different
  // tenants can both have a user with the same IdP-side externalId
  // without colliding. Null for non-SCIM-provisioned users.
  externalId            String?
  evaluationMemberships EvaluationMember[]
  domainAssignments     EvaluationDomainAssignment[] @relation("DomainAssignments")
  notifications         Notification[]
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@unique([institutionId, externalId])
  @@index([institutionId])
  @@index([deletedAt])
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTION_ADMIN
  PROCUREMENT_LEAD
  EVALUATOR
  VENDOR_ADMIN
  VENDOR_CONTRIBUTOR
  VIEWER
}

// ── Vendor Systems ───────────────────────────────────────────────────────────

model VendorSystem {
  id                      String                   @id @default(cuid())
  name                    String
  vendor                  String
  category                String
  description             String?
  regions                 String[]
  cloudNative             Boolean                  @default(false)
  website                 String?
  logoUrl                 String?
  isOwnSystem             Boolean                  @default(false)
  scores                  CapabilityScore[]
  profile                 VendorProfile?
  versions                VendorVersion[]
  tcoEstimates            TcoEstimate[]
  shortlistEntries        ShortlistEntry[]
  integrationTargets      IntegrationAssessment[]
  architectureAssessments ArchitectureAssessment[]
  valueAnalyses           ValueAnalysis[]
  evaluations             ProcurementEvaluation[]
  vendorAccount           VendorAccount?
  evaluationEntries       EvaluationSystem[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model CapabilityScore {
  id           String       @id @default(cuid())
  frameworkId  String
  framework    Framework    @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  systemId     String
  system       VendorSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  capabilityId String
  capability   Capability   @relation(fields: [capabilityId], references: [id], onDelete: Restrict)
  value        Int
  evidence     String?
  source       String?
  version      Int          @default(1)
  scoredBy     String?
  scoredAt     DateTime     @default(now())

  @@unique([frameworkId, systemId, capabilityId, version])
  @@index([frameworkId])
  @@index([systemId])
  @@index([capabilityId])
}

model CapabilityBasket {
  id            String       @id @default(cuid())
  name          String
  description   String?
  frameworkId   String?
  framework     Framework?   @relation(fields: [frameworkId], references: [id], onDelete: SetNull)
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  createdById   String
  items         BasketItem[]
  isTemplate    Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([frameworkId])
  @@index([institutionId])
}

model BasketItem {
  id           String           @id @default(cuid())
  basketId     String
  basket       CapabilityBasket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  capabilityId String
  capability   Capability       @relation(fields: [capabilityId], references: [id], onDelete: Restrict)
  priority     String           @default("must")
  weight       Int              @default(1)
  notes        String?

  @@unique([basketId, capabilityId])
}

model ProcurementProject {
  id               String                  @id @default(cuid())
  name             String
  description      String?
  institutionId    String
  institution      Institution             @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  status           String                  @default("draft")
  basketId         String?
  jurisdiction     String                  @default("UK")
  estimatedValue   Decimal?                @db.Decimal(14, 2)
  procurementRoute String?                 @default("open")
  startDate        DateTime?
  targetAwardDate  DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  workflow         ProcurementWorkflow?
  shortlist        ShortlistEntry[]
  stages           ProcurementStage[]
  evaluations      ProcurementEvaluation[]
  complianceChecks ComplianceCheck[]

  @@index([institutionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  changes    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}

model VendorVersion {
  id          String         @id @default(cuid())
  systemId    String
  system      VendorSystem   @relation(fields: [systemId], references: [id], onDelete: Cascade)
  versionName String
  releaseDate DateTime?
  endOfLife   DateTime?
  changelog   String?
  scores      VersionScore[]
  createdAt   DateTime       @default(now())

  @@index([systemId])
}

model VersionScore {
  id             String        @id @default(cuid())
  frameworkId    String
  framework      Framework     @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  versionId      String
  version        VendorVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  capabilityId   String
  capability     Capability    @relation(fields: [capabilityId], references: [id], onDelete: Restrict)
  value          Int
  changeFromPrev Int?
  evidence       String?

  @@unique([frameworkId, versionId, capabilityId])
  @@index([frameworkId])
  @@index([versionId])
}

model VendorProfile {
  id                   String       @id @default(cuid())
  systemId             String       @unique
  system               VendorSystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  foundedYear          Int?
  headquarters         String?
  employees            String?
  marketShare          String?
  gartnerPosition      String?
  deploymentModel      String[]
  techStack            String?
  apiStandards         String[]
  integrationProtocols String[]
  certifications       String[]
  pricingModel         String?
  typicalCostRange     String?
  implementationTime   String?
  keyStrengths         String[]
  knownLimitations     String[]
  recentNews           String?
  lastUpdated          DateTime     @default(now())
}

model ResearchItem {
  id              String   @id @default(cuid())
  title           String
  publisher       String
  year            Int
  category        String
  tags            String[]
  summary         String?
  url             String?
  relevantSystems String[]
  createdAt       DateTime @default(now())
}

model ScoringMethodology {
  id        String   @id @default(cuid())
  category  String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  role      String
  content   String
  context   Json?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
  @@index([sessionId, userId])
}

model TcoEstimate {
  id                 String        @id @default(cuid())
  name               String
  institutionSize    String
  studentFte         Int
  staffFte           Int
  currency           String        @default("GBP")
  horizonYears       Int           @default(5)
  systemId           String?
  system             VendorSystem? @relation(fields: [systemId], references: [id], onDelete: SetNull)
  licenceCostYear1   Float         @default(0)
  licenceCostGrowth  Float         @default(0.03)
  implementationCost Float         @default(0)
  internalStaffCost  Float         @default(0)
  trainingCost       Float         @default(0)
  infrastructureCost Float         @default(0)
  integrationCost    Float         @default(0)
  supportCost        Float         @default(0)
  customDevCost      Float         @default(0)
  totalTco           Float         @default(0)
  annualRunRate      Float         @default(0)
  perStudentCost     Float         @default(0)
  notes              String?
  institutionId      String?
  createdById        String        @default("anonymous")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([systemId])
  @@index([institutionId])
}

model ProcurementWorkflow {
  id           String             @id @default(cuid())
  projectId    String             @unique
  project      ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentStage Int                @default(1)
  stages       WorkflowStage[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model WorkflowStage {
  id          String              @id @default(cuid())
  workflowId  String
  workflow    ProcurementWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stageNumber Int
  title       String
  status      String              @default("pending")
  completedAt DateTime?
  notes       String?
  outputs     Json?

  @@unique([workflowId, stageNumber])
  @@index([workflowId])
}

model ShortlistEntry {
  id        String             @id @default(cuid())
  projectId String
  project   ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  systemId  String
  system    VendorSystem       @relation(fields: [systemId], references: [id], onDelete: Restrict)
  status    String             @default("longlist")
  score     Float?
  notes     String?
  addedAt   DateTime           @default(now())

  // ── Governance (Phase 3 additive) ────────────────────────────────────────
  // Decision workflow for an entry: 'pending' → 'approved' | 'rejected'.
  // `rationale` captures why the entry is included/excluded; `decidedBy` +
  // `decidedAt` are reviewer attribution when a decision is recorded.
  decisionStatus String    @default("pending")
  rationale      String?
  decidedBy      String?
  decidedAt      DateTime?

  @@unique([projectId, systemId])
  @@index([projectId])
}

model IntegrationAssessment {
  id              String        @id @default(cuid())
  name            String
  currentSystems  Json
  targetSystemId  String?
  targetSystem    VendorSystem? @relation(fields: [targetSystemId], references: [id], onDelete: SetNull)
  complexityScore Int           @default(0)
  riskLevel       String        @default("medium")
  findings        Json?
  institutionId   String?
  createdById     String        @default("anonymous")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([targetSystemId])
  @@index([createdById])
  @@index([institutionId])
}

// ── Architecture & System Landscape Assessment ────────────────────────────────

model ArchitectureAssessment {
  id                  String        @id @default(cuid())
  name                String
  institutionId       String?
  currentSystems      Json
  integrationLinks    Json
  architecturePattern String        @default("point-to-point")
  targetSystemId      String?
  targetSystem        VendorSystem? @relation(fields: [targetSystemId], references: [id], onDelete: SetNull)
  dataRisk            Int           @default(0)
  cutoverRisk         Int           @default(0)
  integrationRisk     Int           @default(0)
  changeRisk          Int           @default(0)
  overallRisk         Int           @default(0)
  readinessScore      Int           @default(0)
  recommendations     Json?
  notes               String?
  createdById         String        @default("anonymous")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([institutionId])
  @@index([createdById])
}

// ── Cost & Value Analysis (Business Case Builder) ─────────────────────────────

model ValueAnalysis {
  id                      String        @id @default(cuid())
  name                    String
  institutionId           String?
  systemId                String?
  targetSystem            VendorSystem? @relation(fields: [systemId], references: [id], onDelete: SetNull)
  studentFte              Int           @default(10000)
  staffFte                Int           @default(500)
  institutionType         String        @default("pre-92")
  currentSystemCostAnnual Float         @default(0)
  currentMaintenanceCost  Float         @default(0)
  currentSupportCost      Float         @default(0)
  adminEfficiencyPct      Float         @default(0)
  adminStaffAffected      Int           @default(0)
  avgAdminSalaryGbp       Float         @default(35000)
  registryEfficiencyPct   Float         @default(0)
  registryStaffAffected   Int           @default(0)
  avgRegistrySalaryGbp    Float         @default(42000)
  errorReductionPct       Float         @default(0)
  errorCostCurrentAnnual  Float         @default(0)
  complianceSavingAnnual  Float         @default(0)
  studentExperienceValue  Float         @default(0)
  otherBenefitsAnnual     Float         @default(0)
  implementationCost      Float         @default(0)
  annualLicenceCost       Float         @default(0)
  annualSupportCost       Float         @default(0)
  annualInternalStaffCost Float         @default(0)
  totalAnnualBenefits     Float         @default(0)
  totalAnnualCosts        Float         @default(0)
  netAnnualBenefit        Float         @default(0)
  roi3Year                Float         @default(0)
  roi5Year                Float         @default(0)
  npv5Year                Float         @default(0)
  paybackMonths           Int           @default(0)
  notes                   String?
  createdById             String        @default("anonymous")
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([systemId])
  @@index([institutionId])
}

// ── Document Generation ───────────────────────────────────────────────────────

model GeneratedDocument {
  id              String         @id @default(cuid())
  title           String
  type            DocumentType
  institutionId   String?
  projectId       String?
  basketId        String?
  tcoEstimateId   String?
  valueAnalysisId String?
  sections        Json
  metadata        Json?
  status          DocumentStatus @default(DRAFT)
  wordCount       Int            @default(0)
  createdById     String         @default("anonymous")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([institutionId])
  @@index([projectId])
  @@index([createdById])
}

enum DocumentType {
  BUSINESS_CASE
  RFP_ITT
  SHORTLIST_REPORT
  REQUIREMENTS_SPEC
  EXECUTIVE_SUMMARY
}

enum DocumentStatus {
  DRAFT
  REVIEW
  FINAL
  ARCHIVED
}

// ── Multi-Jurisdiction Procurement Engine ─────────────────────────────────────

model ProcurementJurisdiction {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  legislation        String
  thresholds         Json
  minimumTimelines   Json
  mandatoryStages    Json
  noticeRequirements Json
  standstillPeriod   Int?
  rules              Json
  isActive           Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model ProcurementStage {
  id               String             @id @default(cuid())
  projectId        String
  project          ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageCode        String
  stageName        String
  stageOrder       Int
  status           StageStatus        @default(NOT_STARTED)
  startDate        DateTime?
  dueDate          DateTime?
  completedDate    DateTime?
  assignedTo       String?
  complianceChecks Json?
  notes            String?
  documents        StageDocument[]
  approvals        StageApproval[]
  tasks            StageTask[]

  @@unique([projectId, stageCode])
  @@index([projectId])
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  AWAITING_APPROVAL
  APPROVED
  COMPLETED
  SKIPPED
  BLOCKED
}

model StageTask {
  id          String           @id @default(cuid())
  stageId     String
  stage       ProcurementStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  title       String
  description String?
  assignedTo  String?
  dueDate     DateTime?
  isCompleted Boolean          @default(false)
  isMandatory Boolean          @default(false)
  completedAt DateTime?
  completedBy String?
  sortOrder   Int

  @@index([stageId])
}

model StageApproval {
  id           String           @id @default(cuid())
  stageId      String
  stage        ProcurementStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  approverRole String
  approverName String?
  status       String           @default("pending")
  requestedAt  DateTime         @default(now())
  decidedAt    DateTime?
  comments     String?

  @@index([stageId])
}

model StageDocument {
  id                    String           @id @default(cuid())
  stageId               String
  stage                 ProcurementStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  documentType          String
  title                 String
  content               Json?
  status                String           @default("draft")
  version               Int              @default(1)
  generatedFromTemplate Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([stageId])
}

model ProcurementEvaluation {
  id                  String             @id @default(cuid())
  projectId           String
  project             ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  systemId            String
  system              VendorSystem       @relation(fields: [systemId], references: [id], onDelete: Restrict)
  evaluatorId         String?
  evaluatorName       String?
  frameworkScore      Decimal?           @db.Decimal(5, 2)
  technicalScore      Decimal?           @db.Decimal(5, 2)
  commercialScore     Decimal?           @db.Decimal(5, 2)
  implementationScore Decimal?           @db.Decimal(5, 2)
  referenceScore      Decimal?           @db.Decimal(5, 2)
  overallScore        Decimal?           @db.Decimal(5, 2)
  weightingProfile    Json?
  recommendation      String?
  notes               String?
  submittedAt         DateTime?

  @@unique([projectId, systemId, evaluatorId])
  @@index([projectId])
}

model ComplianceCheck {
  id             String             @id @default(cuid())
  projectId      String
  project        ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checkCode      String
  checkName      String
  jurisdictionId String
  isRequired     Boolean
  isPassed       Boolean?
  evidence       String?
  checkedAt      DateTime?
  checkedBy      String?

  @@index([projectId])
}

// ── Vendor Portal, Team Workspaces, Payments ─────────────────────────────────

model VendorAccount {
  id                   String             @id @default(cuid())
  companyName          String
  contactEmail         String             @unique
  contactName          String
  systemId             String?            @unique
  system               VendorSystem?      @relation(fields: [systemId], references: [id], onDelete: SetNull)
  tier                 VendorTier         @default(BASIC)
  status               String             @default("pending")
  websiteUrl           String?
  phone                String?
  address              String?
  logoUrl              String?
  description          String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  approvedAt           DateTime?
  approvedBy           String?
  users                VendorUser[]
  submissions          VendorSubmission[]
  analytics            VendorAnalytic[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum VendorTier {
  BASIC
  ENHANCED
  PREMIUM
}

model VendorUser {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  role            String        @default("contributor")
  vendorAccountId String
  vendorAccount   VendorAccount @relation(fields: [vendorAccountId], references: [id], onDelete: Cascade)
  passwordHash    String
  lastLogin       DateTime?
  createdAt       DateTime      @default(now())

  @@index([vendorAccountId])
}

model VendorSubmission {
  id              String        @id @default(cuid())
  vendorAccountId String
  vendorAccount   VendorAccount @relation(fields: [vendorAccountId], references: [id], onDelete: Cascade)
  type            String
  data            Json
  status          String        @default("pending")
  reviewedBy      String?
  reviewNotes     String?
  submittedAt     DateTime      @default(now())
  reviewedAt      DateTime?

  @@index([vendorAccountId])
}

model VendorAnalytic {
  id              String        @id @default(cuid())
  vendorAccountId String
  vendorAccount   VendorAccount @relation(fields: [vendorAccountId], references: [id], onDelete: Cascade)
  metric          String
  value           Int
  period          String
  createdAt       DateTime      @default(now())

  @@index([vendorAccountId, metric, period])
}

model EvaluationProject {
  id                String                       @id @default(cuid())
  name              String
  description       String?
  frameworkId       String?
  framework         Framework?                   @relation(fields: [frameworkId], references: [id], onDelete: SetNull)
  institutionId     String
  institution       Institution                  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  leadUserId        String
  status            String                       @default("planning")
  basketId          String?
  deadline          DateTime?
  systems           EvaluationSystem[]
  members           EvaluationMember[]
  domainAssignments EvaluationDomainAssignment[]
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([frameworkId])
  @@index([institutionId])
}

model EvaluationSystem {
  id        String            @id @default(cuid())
  projectId String
  project   EvaluationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  systemId  String
  system    VendorSystem      @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([projectId, systemId])
}

model EvaluationMember {
  id              String            @id @default(cuid())
  projectId       String
  project         EvaluationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String            @default("evaluator")
  assignedDomains String[]

  @@unique([projectId, userId])
}

model EvaluationDomainAssignment {
  id           String                  @id @default(cuid())
  projectId    String
  project      EvaluationProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domainId     String
  domain       FrameworkDomain         @relation(fields: [domainId], references: [id], onDelete: Restrict)
  assignedToId String
  assignedTo   User                    @relation("DomainAssignments", fields: [assignedToId], references: [id], onDelete: Cascade)
  status       String                  @default("pending")
  score        Json?
  completedAt  DateTime?
  scores       EvaluationDomainScore[]

  @@unique([projectId, domainId])
}

model EvaluationDomainScore {
  id           String                     @id @default(cuid())
  assignmentId String
  assignment   EvaluationDomainAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  systemId     String
  capabilityId String
  value        Int
  notes        String?
  scoredAt     DateTime                   @default(now())

  @@unique([assignmentId, systemId, capabilityId])
}

model Payment {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("GBP")
  status          String
  stripePaymentId String?      @unique
  invoiceUrl      String?
  paidAt          DateTime?
  createdAt       DateTime     @default(now())

  @@index([subscriptionId])
}

// ── Notifications & API Keys ─────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model ApiKey {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  keyHash       String      @unique
  keyPrefix     String
  permissions   String[]
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  @@index([institutionId])
}

// ── Framework Mapping (Enterprise tier) ──────────────────────────────────────

model FrameworkMapping {
  id                String              @id @default(cuid())
  sourceFrameworkId String
  sourceFramework   Framework           @relation("MappingSource", fields: [sourceFrameworkId], references: [id], onDelete: Cascade)
  targetFrameworkId String
  targetFramework   Framework           @relation("MappingTarget", fields: [targetFrameworkId], references: [id], onDelete: Cascade)
  name              String // "HERM v3.1 → FHE v1.0"
  description       String?
  mappingType       String // "official" | "community" | "custom"
  createdBy         String
  isActive          Boolean             @default(true)
  items             CapabilityMapping[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([sourceFrameworkId, targetFrameworkId, name])
  @@index([sourceFrameworkId])
  @@index([targetFrameworkId])
}

model CapabilityMapping {
  id                 String           @id @default(cuid())
  mappingId          String
  mapping            FrameworkMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  sourceCapabilityId String
  sourceCapability   Capability       @relation("SourceCapabilityMapping", fields: [sourceCapabilityId], references: [id], onDelete: Cascade)
  targetCapabilityId String
  targetCapability   Capability       @relation("TargetCapabilityMapping", fields: [targetCapabilityId], references: [id], onDelete: Cascade)
  strength           String           @default("partial") // "exact" | "strong" | "partial" | "weak"
  confidence         Int              @default(50) // 0-100
  notes              String?

  @@unique([mappingId, sourceCapabilityId, targetCapabilityId])
  @@index([mappingId])
  @@index([sourceCapabilityId])
  @@index([targetCapabilityId])
}
