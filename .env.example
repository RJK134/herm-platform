# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://herm:herm_dev_2026@localhost:5432/herm_platform"
REDIS_URL="redis://localhost:6379"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV="development"

# ── Frontend URL (used for CORS — set to your deployed frontend URL in prod) ──
FRONTEND_URL="http://localhost:5173"

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# In production this MUST be set — the server will refuse to start without it.
JWT_SECRET="change-me-in-production-use-a-long-random-string"

# ── Anthropic AI (required for the AI Assistant chat feature) ─────────────────
# Get your key from https://console.anthropic.com
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY="sk-ant-api03-REPLACE_WITH_YOUR_KEY"

# ── Stripe (required for subscription billing) ───────────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_KEY"
# Get your webhook secret from https://dashboard.stripe.com/webhooks
# (used to verify webhook signatures — prevents spoofed payment events)
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET"
