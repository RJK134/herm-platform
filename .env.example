# ── Database ─────────────────────────────────────────────────────────────────
# Host ports match docker-compose.yml (offset to avoid colliding with any local
# Postgres/Redis on 5432/6379). Inside the containers the services still listen
# on their default ports.
DATABASE_URL="postgresql://herm:herm_dev_2026@localhost:5434/herm_platform"
REDIS_URL="redis://localhost:6380"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV="development"
# Set to "production" when deploying — enables strict startup checks and hides
# internal error details from API responses.

# ── Frontend URL (used for CORS) ──────────────────────────────────────────────
# Set to your deployed frontend URL in production (e.g. https://app.example.com)
FRONTEND_URL="http://localhost:5173"

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production — server refuses to start without it.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters; 64+ recommended.
JWT_SECRET="change-me-in-production-use-a-long-random-string"

# ── Anthropic AI (required for the AI Assistant chat feature) ─────────────────
# Get your key from https://console.anthropic.com
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY="sk-ant-api03-REPLACE_WITH_YOUR_KEY"

# ── Observability (Sentry) ───────────────────────────────────────────────────
# Optional. When SENTRY_DSN is unset the server runs without error reporting
# (no-op). Get the DSN from https://sentry.io → project settings → Client Keys.
# Format: https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT defaults to NODE_ENV; set explicitly when running
# multiple deploys against one Sentry project (e.g. "staging", "preview").
# SENTRY_ENVIRONMENT="production"
# Sample rate for performance traces (0.0–1.0). Default 0 = error capture only.
# SENTRY_TRACES_SAMPLE_RATE="0"

# ── Stripe (required for subscription billing) ───────────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_KEY"
# Get your webhook secret from https://dashboard.stripe.com/webhooks
# (used to verify webhook signatures — prevents spoofed payment events)
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET"

# ── SMTP / Outbound email ────────────────────────────────────────────────────
# Optional. When SMTP_HOST is unset, every send is a no-op (dev-friendly).
# In production, set these to enable billing-event emails to institution admins
# (payment failed, refund issued, dispute opened, tier change).
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# Set SMTP_SECURE="true" for SMTPS (port 465). Leave unset on STARTTLS (587).
# SMTP_SECURE="false"
# SMTP_USER and SMTP_PASSWORD authenticate to the relay. Hosted providers
# typically use a literal username (e.g. "apikey" for SendGrid) and the
# password is the provider's API token / server token.
# SMTP_USER="REPLACE_WITH_USERNAME"
# SMTP_PASSWORD="REPLACE_WITH_API_TOKEN"
# SMTP_FROM is the From: address shown to recipients. RFC-5322 mailbox form
# accepted (e.g. "HERM Platform <noreply@your-domain.example>").
# SMTP_FROM="HERM Platform <noreply@your-domain.example>"

# ── Pre-billing tier override ────────────────────────────────────────────────
# When set to "true", every logged-in user is issued a JWT with tier="enterprise",
# so colleagues testing the platform can exercise Enterprise-gated surfaces
# (Framework Mapping, Sector Analytics, etc.) before real subscriptions exist.
# MUST be unset (or "false") in production — env-check will warn loudly if not.
# Remove this section entirely once real billing lands.
# DEV_UNLOCK_ALL_TIERS="false"

# ── Production deployment checklist ──────────────────────────────────────────
# 1. Set NODE_ENV=production
# 2. Set a strong JWT_SECRET (64-byte random hex — see command above)
# 3. Set FRONTEND_URL to your deployed frontend domain
# 4. Set DATABASE_URL to your production PostgreSQL connection string
# 5. Run migrations: npm run db:migrate:deploy
# 6. Run seed (first time only): npx tsx prisma/seed.ts
# 7. Configure ANTHROPIC_API_KEY and Stripe keys if those features are needed
